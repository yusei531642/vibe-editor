{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "vibe-editor renderer permissions: 全 IPC + event listen を許可。Phase 1 では全 #[tauri::command] を allowlist する",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-unlisten",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:app:default",
    "dialog:default",
    "shell:default",
    "opener:default",
    "process:default",
    "updater:default"
  ]
}
