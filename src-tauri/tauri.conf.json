{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibe-editor",
  "version": "1.2.1",
  "identifier": "com.vibe-editor.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vibe-editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://api.github.com; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'; frame-src 'none'; worker-src 'self' blob:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "vibe-editor"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 vibe-editor",
    "category": "DeveloperTool",
    "shortDescription": "AI エージェント時代のエディタ",
    "longDescription": "Claude Code / Codex 専用エディタ。マルチエージェント・無限キャンバス対応。",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Japanese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/yusei531642/vibe-editor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzRDgwRjA3ODVBODIyNkQKUldSdElxaUZCdy9ZdzlOaHhvOVJnZXhkc0NqbHNqTUlIbEVObW9LTlpOSnp3UzMwWTdHSXllTWMK"
    }
  }
}
